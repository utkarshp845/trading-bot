BOT_PROFILE=paper
SYMBOL=BTC/USD
IS_CRYPTO=true
ALPACA_PAPER=true
RESEARCH_STARTING_EQUITY=250
RESEARCH_OUTPUT_STEM=research_paper_btc

# 24/7 crypto — no market-hours session management
ALLOW_OVERNIGHT_HOLDING=true
FLATTEN_BEFORE_CLOSE_MINUTES=0
ENTRY_WINDOWS=0000-2359
LONG_ENTRY_WINDOWS=0000-2359
SHORT_ENTRY_WINDOWS=0000-2359
ALLOW_SHORTS=false

# Fractional BTC sizing — ATR-risk formula capped by notional limit
POSITION_SIZING_MODE=atr_risk
ATR_RISK_PER_TRADE_PCT=0.02
MAX_POSITION_NOTIONAL_PCT=0.50
TARGET_POSITION_NOTIONAL_PCT=0.50
MIN_ORDER_NOTIONAL=1.0

# Exit management
HARD_STOP_ATR_MULT=2.5
TRAIL_AFTER_ATR_MULTIPLE=1.5
TRAIL_ATR_MULTIPLIER=2.0
MAX_BARS_IN_TRADE=18
EXIT_ON_REGIME_INVALIDATION=true
ENABLE_BREAKEVEN_STOP=true
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=false
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5

# --- CORE SIGNAL FILTERS ---
# SMA trend direction: fast > slow handled by strategy logic

# ADX: trend must have some strength, but not as demanding as live config
ADX_THRESHOLD=20
LONG_ADX_THRESHOLD=20

# ATR% cap: raised to 2.5% to accommodate BTC's normal volatility range
ATR_MAX_PCT=0.025
LONG_ATR_MAX_PCT=0.025

# Volume: light minimum — just needs to be active
MIN_VOLUME_RATIO=1.0
VOLUME_MIN_MULTIPLIER=1.0

# Trend EMA: keep as directional filter (price > EMA55 and SMA20 >= EMA55)
# but remove the distance minimum so it doesn't over-filter
EXEC_TREND_EMA_PERIOD=55
LONG_MIN_TREND_EMA_DISTANCE_PCT=0
SHORT_MIN_TREND_EMA_DISTANCE_PCT=0

# Regime: simplified to just "is BTC above its 4-day hourly EMA?"
# Remove ADX, slope, and ATR requirements — those killed all signals
REGIME_TIMEFRAME_MINUTES=60
REGIME_EMA_PERIOD=96
REGIME_ADX_PERIOD=14
REGIME_ADX_MIN=0
REGIME_SLOPE_LOOKBACK_BARS=3
REGIME_MIN_SLOPE_PCT=0
REGIME_ATR_MAX_PCT=1.0

# --- DISABLED FILTERS (re-enable one at a time after baseline is established) ---

# Momentum: off
MOMENTUM_LOOKBACK_BARS=0

# SMA spread minimum: off
MIN_SMA_SPREAD_ATR_MULT=0

# ADX must be accelerating: off
MIN_ADX_DELTA=0

# Pullback depth window: fully open (0 to 99 ATR)
PULLBACK_MIN_DEPTH_ATR=0
PULLBACK_MAX_DEPTH_ATR=99

# Reaccel bar: just requires a bullish close above prior close (body threshold = 0)
REACCEL_MIN_BAR_BODY_ATR=0

# Spike bar filter: very permissive
SPIKE_BAR_MAX_RANGE_ATR=10

# --- RISK LIMITS ---
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_DAILY_LOSS=4
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=4
MAX_CONSECUTIVE_ENTRY_FAILURES_PER_DAY=2

# Data quality
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=600

# Entry throttles
COOLDOWN_BARS=3
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false
