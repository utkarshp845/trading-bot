BOT_PROFILE=paper
SYMBOL=BTC/USD
IS_CRYPTO=true
ALPACA_PAPER=true
RESEARCH_STARTING_EQUITY=250
RESEARCH_OUTPUT_STEM=research_paper_btc

# 24/7 crypto — no market-hours session management
ALLOW_OVERNIGHT_HOLDING=true
FLATTEN_BEFORE_CLOSE_MINUTES=0
ENTRY_WINDOWS=0000-2359
LONG_ENTRY_WINDOWS=0000-2359
SHORT_ENTRY_WINDOWS=0000-2359

# Fractional BTC sizing — mirror the live profile so paper is a true rehearsal
POSITION_SIZING_MODE=atr_risk
ATR_RISK_PER_TRADE_PCT=0.0025
MAX_POSITION_NOTIONAL_PCT=0.50
TARGET_POSITION_NOTIONAL_PCT=0.50

# Hard stop and exit management
HARD_STOP_ATR_MULT=3.0
TRAIL_ATR_MULTIPLIER=2.0
MAX_BARS_IN_TRADE=24
ENABLE_BREAKEVEN_STOP=true
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=true
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5

# Volatility and trend filters
ATR_MAX_PCT=0.008
LONG_ATR_MAX_PCT=0.006
SHORT_ATR_MAX_PCT=0.008
ADX_THRESHOLD=20
LONG_ADX_THRESHOLD=25
MIN_SMA_SPREAD_ATR_MULT=0.4
REVERSAL_SIGNAL_STRENGTH_MIN=35
TREND_EMA_PERIOD=55
LONG_MIN_TREND_EMA_DISTANCE_PCT=0.0015
SHORT_MIN_TREND_EMA_DISTANCE_PCT=0.0015
MOMENTUM_LOOKBACK_BARS=3
LONG_MIN_MOMENTUM_PCT=0.003
SHORT_MIN_MOMENTUM_PCT=0.003
MIN_ADX_DELTA=0.25

# Daily risk limits — same small-account guardrails as live BTC
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_DAILY_LOSS=10
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=8

# Data quality
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=600

# Entry throttles
COOLDOWN_BARS=3
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false
