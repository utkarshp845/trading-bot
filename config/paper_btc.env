BOT_PROFILE=paper
SYMBOL=BTC/USD
IS_CRYPTO=true
ALPACA_PAPER=true
RESEARCH_STARTING_EQUITY=150
RESEARCH_OUTPUT_STEM=research_paper_btc
STRATEGY_VERSION=v3-btc-defensive-trend

# DEFENSIVE profile. Evidence (docs/strategy_revamp_2026-07.md): on a ~$150
# account, Alpaca crypto friction (~0.25% taker + spread per side) exceeds any
# repeatable intraday edge. The old 5m scalp stack fired twice in 120 days and
# every "more active" variant lost money in replay — activity itself is the
# cost. This config only trades textbook 4h uptrends with wide trails:
# it took ZERO trades in the 2025-26 bear replay (BTC -46%) and was mildly
# positive in the 2024-25 bull replay. Prefer the equity profile for growth.
TIMEFRAME_MINUTES=60

# 24/7 crypto — no market-hours session management
ALLOW_OVERNIGHT_HOLDING=true
FLATTEN_BEFORE_CLOSE_MINUTES=0
ENTRY_WINDOWS=0000-2359
LONG_ENTRY_WINDOWS=0000-2359
SHORT_ENTRY_WINDOWS=0000-2359
ALLOW_SHORTS=false

# Near-full-notional sizing: $45 positions can never outrun fees. One position,
# ~90% of equity, stop ~2.5 hourly ATRs (~2-3% of position).
POSITION_SIZING_MODE=notional_cap
MAX_POSITION_NOTIONAL_PCT=0.95
TARGET_POSITION_NOTIONAL_PCT=0.90
ATR_RISK_PER_TRADE_PCT=0.0075
MIN_ORDER_NOTIONAL=1.0

# Exits: wide trail so the rare winner runs for days; that is the only way a
# trade can clear ~0.6% round-trip friction with room to spare.
HARD_STOP_ATR_MULT=2.5
TRAIL_AFTER_ATR_MULTIPLE=3.0
TRAIL_ATR_MULTIPLIER=3.0
MAX_BARS_IN_TRADE=999
EXIT_ON_REGIME_INVALIDATION=true
ENABLE_BREAKEVEN_STOP=false
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=false
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5

# Core signal on hourly bars
SMA_FAST=20
SMA_SLOW=50
EXEC_TREND_EMA_PERIOD=55
ADX_THRESHOLD=20
LONG_ADX_THRESHOLD=20
ATR_MAX_PCT=0.03
LONG_ATR_MAX_PCT=0.03
LONG_MIN_TREND_EMA_DISTANCE_PCT=0
SHORT_MIN_TREND_EMA_DISTANCE_PCT=0

# Micro-filters off — replay showed they only added noise. Alpaca BTC volume
# data is too thin (many bars trade 0.0001 BTC) for volume filters to mean anything.
MIN_VOLUME_RATIO=0
VOLUME_MIN_MULTIPLIER=0
MOMENTUM_LOOKBACK_BARS=0
MIN_SMA_SPREAD_ATR_MULT=0
MIN_ADX_DELTA=0
PULLBACK_MIN_DEPTH_ATR=0
PULLBACK_MAX_DEPTH_ATR=99
REACCEL_MIN_BAR_BODY_ATR=0
SPIKE_BAR_MAX_RANGE_ATR=10

# Regime gate: 4h EMA(120) must be rising >=0.8% over 24h. This is the switch
# that kept the strategy flat through the entire 2025-26 bear.
REGIME_TIMEFRAME_MINUTES=240
REGIME_EMA_PERIOD=120
REGIME_ADX_PERIOD=14
REGIME_ADX_MIN=0
REGIME_SLOPE_LOOKBACK_BARS=6
REGIME_MIN_SLOPE_PCT=0.008
REGIME_ATR_MAX_PCT=1.0

# Daily risk limits for roughly $150 live capital
MAX_DAILY_DRAWDOWN_PCT=0.04
MAX_DAILY_LOSS=6
MAX_CONSECUTIVE_LOSSES=3
MAX_TRADES_PER_DAY=2
MAX_CONSECUTIVE_ENTRY_FAILURES_PER_DAY=3
COOLDOWN_BARS=4
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false

# Hourly bars: allow up to 1.5 bars of age before calling data stale.
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=5400
