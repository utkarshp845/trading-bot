BOT_PROFILE=live
SYMBOL=BTC/USD
IS_CRYPTO=true
ALPACA_PAPER=false

# 24/7 crypto — no market-hours session management
ALLOW_OVERNIGHT_HOLDING=true
FLATTEN_BEFORE_CLOSE_MINUTES=0
ENTRY_WINDOWS=0000-2359
LONG_ENTRY_WINDOWS=0000-2359
SHORT_ENTRY_WINDOWS=0000-2359
ALLOW_SHORTS=false

# Fractional BTC sizing — risk 0.25% of equity per ATR unit, cap at 50% notional
POSITION_SIZING_MODE=atr_risk
ATR_RISK_PER_TRADE_PCT=0.0025
MAX_POSITION_NOTIONAL_PCT=0.50
TARGET_POSITION_NOTIONAL_PCT=0.50

# Hard stop: exit if price moves 2.5x ATR against entry
HARD_STOP_ATR_MULT=2.5

# Trailing stop activates only after real follow-through
TRAIL_AFTER_ATR_MULTIPLE=1.5
TRAIL_ATR_MULTIPLIER=2.0
MAX_BARS_IN_TRADE=18
EXIT_ON_REGIME_INVALIDATION=true

# Ratchet to breakeven, but no partial take-profit logic in this profile
ENABLE_BREAKEVEN_STOP=true
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=false
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5

# ATR volatility filter — BTC ATR% runs higher than equities; allow up to 0.8%
ATR_MAX_PCT=0.008
LONG_ATR_MAX_PCT=0.006
SHORT_ATR_MAX_PCT=0.008

# Trend filter — only trade when higher-timeframe BTC structure is healthy
ADX_THRESHOLD=20
LONG_ADX_THRESHOLD=25
REGIME_TIMEFRAME_MINUTES=60
REGIME_EMA_PERIOD=96
REGIME_ADX_PERIOD=14
REGIME_ADX_MIN=18
REGIME_SLOPE_LOOKBACK_BARS=3
REGIME_MIN_SLOPE_PCT=0.002
REGIME_ATR_MAX_PCT=0.02

# Daily risk limits — $10 max daily loss on a $100 account
MAX_DAILY_DRAWDOWN_PCT=0.05
MAX_DAILY_LOSS=10
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=4
MAX_CONSECUTIVE_ENTRY_FAILURES_PER_DAY=2

# Data quality
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=600

# Signal quality — continuation entries, not all-day churn
COOLDOWN_BARS=6
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false
MIN_SMA_SPREAD_ATR_MULT=0.2
EXEC_TREND_EMA_PERIOD=55
LONG_MIN_TREND_EMA_DISTANCE_PCT=0.0015
SHORT_MIN_TREND_EMA_DISTANCE_PCT=0.0015
MOMENTUM_LOOKBACK_BARS=3
LONG_MIN_MOMENTUM_PCT=0.003
SHORT_MIN_MOMENTUM_PCT=0.003
MIN_ADX_DELTA=0.25
PULLBACK_LOOKBACK_BARS=6
PULLBACK_MIN_DEPTH_ATR=0.4
PULLBACK_MAX_DEPTH_ATR=1.2
REACCEL_MIN_BAR_BODY_ATR=0.2
SPIKE_BAR_MAX_RANGE_ATR=1.8
MIN_VOLUME_RATIO=1.1
