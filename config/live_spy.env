BOT_PROFILE=live
SYMBOL=SPY
IS_CRYPTO=false
ALPACA_PAPER=false

# Small-account SPY profile: fractional, long-only, and morning-biased.
ALLOW_OVERNIGHT_HOLDING=false
FLATTEN_BEFORE_CLOSE_MINUTES=5
ENTRY_WINDOWS=0940-1130
LONG_ENTRY_WINDOWS=0940-1130
SHORT_ENTRY_WINDOWS=0940-1130
ALLOW_SHORTS=false

# One whole SPY share is too large for a roughly $150 account.
ALLOW_FRACTIONAL_EQUITIES=true
POSITION_SIZING_MODE=atr_risk
ATR_RISK_PER_TRADE_PCT=0.005
MAX_POSITION_NOTIONAL_PCT=0.20
TARGET_POSITION_NOTIONAL_PCT=0.15
MIN_ORDER_NOTIONAL=5.0

# Keep daily risk bounded while allowing a little signal sampling.
MAX_DAILY_DRAWDOWN_PCT=0.025
MAX_DAILY_LOSS=3
MAX_CONSECUTIVE_LOSSES=2
MAX_TRADES_PER_DAY=3
MAX_CONSECUTIVE_ENTRY_FAILURES_PER_DAY=2

ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=900
COOLDOWN_BARS=3
