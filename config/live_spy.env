BOT_PROFILE=live
SYMBOL=QQQ
IS_CRYPTO=false
ALPACA_PAPER=false
STRATEGY_VERSION=v3-equity-trend

# Hourly trend-following on QQQ. Validated in replay over 2023-08..2026-07:
# +35% on $150 with PF 1.87 / max DD 5.3% (see docs/strategy_revamp_2026-07.md).
# Equities are the right venue for a $150 account: round-trip friction is
# ~0.02-0.05% vs ~0.6% on Alpaca crypto, which is why the BTC scalp profile bled.
TIMEFRAME_MINUTES=60

# Multi-day trend holds are the whole edge — do NOT flatten daily.
ALLOW_OVERNIGHT_HOLDING=true
FLATTEN_BEFORE_CLOSE_MINUTES=0
ENTRY_WINDOWS=0000-2359
LONG_ENTRY_WINDOWS=0000-2359
SHORT_ENTRY_WINDOWS=0000-2359
ALLOW_SHORTS=false

# Nearly full-notional fractional sizing: with ~$150, diversification is
# impossible and sub-$50 positions cannot outrun even tiny friction.
ALLOW_FRACTIONAL_EQUITIES=true
POSITION_SIZING_MODE=notional_cap
MAX_POSITION_NOTIONAL_PCT=0.95
TARGET_POSITION_NOTIONAL_PCT=0.90
MIN_ORDER_NOTIONAL=5.0

# Exits: wide trail lets winners run for days; hard stop caps single-trade loss
# at ~2.5 hourly ATRs (~1-2% of position).
HARD_STOP_ATR_MULT=2.5
TRAIL_AFTER_ATR_MULTIPLE=2.0
TRAIL_ATR_MULTIPLIER=2.5
MAX_BARS_IN_TRADE=999
EXIT_ON_REGIME_INVALIDATION=true
ENABLE_BREAKEVEN_STOP=false
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=false
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5

# Core signal: SMA20>SMA50, price above EMA55, bullish confirmation bar,
# and the daily regime (close above 20-day EMA) must be on.
SMA_FAST=20
SMA_SLOW=50
EXEC_TREND_EMA_PERIOD=55
ADX_THRESHOLD=15
LONG_ADX_THRESHOLD=15
ATR_MAX_PCT=0.03
LONG_ATR_MAX_PCT=0.03
LONG_MIN_TREND_EMA_DISTANCE_PCT=0
SHORT_MIN_TREND_EMA_DISTANCE_PCT=0

# Micro-filters off: replayed 2023-2026, each of these only removed trades
# without improving expectancy at this timeframe.
MIN_VOLUME_RATIO=0
VOLUME_MIN_MULTIPLIER=0
MOMENTUM_LOOKBACK_BARS=0
MIN_SMA_SPREAD_ATR_MULT=0
MIN_ADX_DELTA=0
PULLBACK_MIN_DEPTH_ATR=0
PULLBACK_MAX_DEPTH_ATR=99
REACCEL_MIN_BAR_BODY_ATR=0
SPIKE_BAR_MAX_RANGE_ATR=10

# Regime: daily bars, price above 20-day EMA. This is what kept the strategy
# out of Feb-Mar 2026 while still catching the April/May leg.
REGIME_TIMEFRAME_MINUTES=1440
REGIME_EMA_PERIOD=20
REGIME_ADX_PERIOD=14
REGIME_ADX_MIN=0
REGIME_SLOPE_LOOKBACK_BARS=3
REGIME_MIN_SLOPE_PCT=0
REGIME_ATR_MAX_PCT=1.0

# Risk limits: cash account, ~2 entries/week expected, holds of days.
MAX_DAILY_DRAWDOWN_PCT=0.04
MAX_DAILY_LOSS=6
MAX_CONSECUTIVE_LOSSES=3
MAX_TRADES_PER_DAY=2
MAX_CONSECUTIVE_ENTRY_FAILURES_PER_DAY=3
COOLDOWN_BARS=2
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false

# Hourly bars: allow up to 1.5 bars of age before calling data stale.
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=5400
