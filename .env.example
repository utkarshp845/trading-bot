# Alpaca paper keys
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY
ALPACA_PAPER=true

# Bot config
SYMBOL=SPY
QTY=1
TIMEFRAME_MINUTES=5
STARTUP_DELAY_SECONDS=20

# Strategy config
SMA_FAST=20
SMA_SLOW=50
ADX_PERIOD=14
ADX_THRESHOLD=25
ATR_PERIOD=14
ATR_MAX_PCT=0.0035
VOLUME_MA_PERIOD=20
VOLUME_MIN_MULTIPLIER=1.05
TRAIL_ATR_MULTIPLIER=1.5
MAX_BARS_IN_TRADE=12
STRATEGY_VERSION=v1
LONG_ADX_THRESHOLD=30
SHORT_ADX_THRESHOLD=
LONG_ATR_MAX_PCT=0.003
SHORT_ATR_MAX_PCT=
LONG_VOLUME_MIN_MULTIPLIER=1.15
SHORT_VOLUME_MIN_MULTIPLIER=1.0
MIN_SMA_SPREAD_ATR_MULT=0
MIN_SMA_SPREAD_PCT=0
USE_VWAP_FILTER=false
MIN_PRICE_DISTANCE_FROM_VWAP_PCT=0
USE_SESSION_OPEN_FILTER=false
MIN_PRICE_DISTANCE_FROM_OPEN_PCT=0
ENTRY_WINDOWS=0940-1130
LONG_ENTRY_WINDOWS=0940-1130
SHORT_ENTRY_WINDOWS=0940-1130
LONG_TRAIL_ATR_MULTIPLIER=
SHORT_TRAIL_ATR_MULTIPLIER=
LONG_MAX_BARS_IN_TRADE=
SHORT_MAX_BARS_IN_TRADE=
ENABLE_BREAKEVEN_STOP=false
BREAKEVEN_AFTER_ATR_MULTIPLE=1.0
ENABLE_PROFIT_LOCK=false
PROFIT_LOCK_AFTER_ATR_MULTIPLE=2.0
PROFIT_LOCK_ATR_MULTIPLE=0.5
REVERSAL_SIGNAL_STRENGTH_MIN=35

# Entry throttles and risk
COOLDOWN_BARS=2
REENTRY_REQUIRES_SIGNAL_STRENGTH_IMPROVEMENT=false
REENTRY_MIN_SIGNAL_STRENGTH_DELTA=0
MAX_TRADES_PER_DAY=5
MAX_DAILY_DRAWDOWN_PCT=0.01
MAX_DAILY_LOSS=0
MAX_CONSECUTIVE_LOSSES=3
ENABLE_STALE_BAR_CHECK=true
MAX_BAR_AGE_SECONDS=900
MAX_POSITION_NOTIONAL_PCT=0.02
ALLOW_ET_MARKET_CLOCK_FALLBACK=false
POSITION_SIZING_MODE=fixed
TARGET_POSITION_NOTIONAL_PCT=0.02
ATR_RISK_PER_TRADE_PCT=0.0025

# Research / replay
RESEARCH_LOOKBACK_DAYS=90
RESEARCH_TRAIN_DAYS=30
RESEARCH_TEST_DAYS=10
RESEARCH_STARTING_EQUITY=100000
RESEARCH_SLIPPAGE_PER_SHARE=0.01
RESEARCH_COMMISSION_PER_TRADE=0
RESEARCH_SIZING_MODE=fixed
RESEARCH_OUTPUT_STEM=research_latest
